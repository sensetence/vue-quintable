{
  "name": "@sensetence/vue-quintable",
  "version": "2.4.0",
  "private": false,
  "scripts": {
    "dev": "vite --config vite.build.config.js",
    "build": "vite build --config vite.build.config.js",
    "prod-local": "vite build --config vite.pack.config.js",
    "prod": "node ./pack.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "test:e2e:update": "npx playwright test --update-snapshots"
  },
  "main": "./dist/vue-quintable.umd.js",
  "module": "./dist/vue-quintable.es.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/vue-quintable.es.js",
      "require": "./dist/vue-quintable.umd.js"
    }
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^1.2.35",
    "@fortawesome/free-solid-svg-icons": "^5.15.3",
    "@fortawesome/vue-fontawesome": "^0.1.10",
    "axios": "^1.13.6",
    "core-js": "^3.9.1",
    "fuzzy.js": "^0.1.0",
    "prismjs": "^1.30.0",
    "uuid": "^3.4.0",
    "v-tooltip": "^2.1.3",
    "vue": "^2.7.1",
    "vue-drag-drop": "^1.1.4",
    "vue-select": "^3.11.2"
  },
  "devDependencies": {

    "@playwright/test": "^1.58.2",
    "@popperjs/core": "^2.9.3",
    "@vitejs/plugin-basic-ssl": "^1.0.1",
    "@vitejs/plugin-vue2": "^2.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "1",
    "autoprefixer": "^10.4.13",
    "bootstrap": "^5.1.0",
    "chance": "^1.1.7",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^3.4.0",
    "eslint-plugin-vue": "^9.4.0",
    "flush-promises": "^1.0.2",
    "jsdom": "^28.1.0",
    "moment-timezone": "^0.5.35",
    "prettier": "2.3.1",
    "pretty-checkbox-vue": "^1.1.9",
    "sanitize-filename": "^1.6.3",
    "sass": "^1.89.0",

    "vite": "^4.5.14",
    "vite-plugin-commonjs": "^0.10.4",
    "vite-plugin-eslint2": "^5.0.5",
    "vite-plugin-rewrite-all": "^1.0.1",
    "vitest": "^4.1.0",
    "vue-template-compiler": "^2.7.14"
  },
  "homepage": "https://sensetence.com/vue-quintable/",
  "keywords": [
    "table",
    "tables",
    "datatable",
    "vue",
    "vue.js",
    "data-table",
    "tables",
    "responsive",
    "vue-datasource",
    "vue-table",
    "vue-quintable"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sensetence/vue-quintable.git"
  },
  "config": {
    "packageName": "vue-quintable"
  },
  "resolutions": {
    "@babel/runtime": "^7.26.10",
    "minimatch": "^3.1.4",
    "brace-expansion": "^1.1.12",
    "cross-spawn": "^7.0.6",
    "ajv": "^6.14.0",
    "nanoid": "^3.3.8",
    "postcss": "^8.4.31",
    "lodash": "^4.17.23",
    "semver": "^7.5.2",
    "flatted": "^3.4.0"
  }
}
